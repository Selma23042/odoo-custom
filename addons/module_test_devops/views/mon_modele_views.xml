<odoo>
  <record id="view_mon_modele_list" model="ir.ui.view">
    <field name="name">mon.modele.list</field>
    <field name="model">mon.modele</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="description"/>
        <field name="actif"/>
        <field name="date_creation"/>
      </list>
    </field>
  </record>

  <record id="action_mon_modele" model="ir.actions.act_window">
    <field name="name">Mon Modele</field>
    <field name="res_model">mon.modele</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem id="menu_mon_modele"
    name="Test DevOps"
    action="action_mon_modele"
    sequence="10"/>
</odoo>